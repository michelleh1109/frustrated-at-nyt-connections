# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Gmail OAuth2 — download from Google Cloud Console
# https://console.cloud.google.com/ → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here

# Path to the credentials JSON you downloaded from Google Cloud Console
# Default: credentials.json in the project root (also gitignored)
GMAIL_CREDENTIALS_PATH=credentials.json

# Where to cache the OAuth token after first login
# This file contains your access + refresh token — keep it private
GMAIL_TOKEN_PATH=token.json

# Your Gmail address (used to sanity-check we're pulling the right inbox)
GMAIL_USER=michellesyhui@gmail.com

# How far back to pull sent mail (YYYY/MM/DD). Default: 3 years ago.
# Older emails are excluded server-side — nothing outside this window downloads.
GMAIL_AFTER_DATE=2023/06/17

# Modal (for training + inference deployment)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Anthropic (for LLM-as-judge eval)
ANTHROPIC_API_KEY=
